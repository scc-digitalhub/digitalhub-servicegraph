FROM python:3.10-slim

WORKDIR /workspace

ENV PYTHONDONTWRITEBYTECODE=1 \
	PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y \
	libgl1 \
	libglib2.0-0 \
	libsm6 \
	libxext6 \
	libxrender1 \
	libxcb1 \
	&& rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
	"flask>=2.3.0" \
	"pillow>=10.0.0" \
	"requests>=2.31.0" \
	"ultralytics>=8.4.14"

CMD ["python", "object_detection_server.py"]