FROM python:3.10-slim

WORKDIR /workspace

ENV PYTHONDONTWRITEBYTECODE=1 \
	PYTHONUNBUFFERED=1

RUN pip install --no-cache-dir \
	"flask>=2.3.0" \
	"pillow>=10.0.0" \
	"requests>=2.31.0" \
	"huggingface-hub>=0.24.0" \
	"torch>=2.3.0" \
	"torchvision>=0.18.0"

CMD ["python", "dog_breed_classifier_server.py"]